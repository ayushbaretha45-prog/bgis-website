<!DOCTYPE html>
<html>
<head>
    
   <style>
body {
  margin: 0;
  padding: 0;
  font-family: Arial;
  color: white;
  text-align: center;

  background: url('/bg.jpg') no-repeat center center fixed;
  background-size: cover;
}

/* DARK OVERLAY (important) */
body::before {
  content: "";
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6);
  z-index: -1;
}

/* Heading clean */
h1 {
  color: #22d3ee;
  text-shadow: none;
}

/* TABLE GLASS EFFECT */
table {
  margin: 30px auto;
  width: 90%;
  border-collapse: collapse;

  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(15px);
  -webkit-backdrop-filter: blur(15px);

  border-radius: 15px;
  overflow: hidden;
  box-shadow: 0 0 30px rgba(140, 0, 255, 0.3);
}

/* HEADER FIX */
th {
  padding: 14px;
  background: rgba(0, 0, 0, 0.6);
  color: #c084fc;
  font-weight: bold;
}

/* CELLS */
td {
  padding: 12px;
}

/* ROWS */
tr:nth-child(even) {
  background: rgba(255,255,255,0.05);
}

tr:hover {
  background: rgba(140, 0, 255, 0.25);
  transition: 0.3s;
}

/* TOP 3 */
tr:nth-child(1) {
  background: linear-gradient(90deg, gold, orange);
  color: black;
}

tr:nth-child(2) {
  background: linear-gradient(90deg, silver, gray);
  color: black;
}

tr:nth-child(3) {
  background: linear-gradient(90deg, #cd7f32, #8b4513);
  color: black;
}
</style>

<script>
setTimeout(() => {
  location.reload();
}, 30000); // 30 sec refresh
</script>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BGIS 2026 Live Standings</title>
    <link rel="stylesheet" href="/style.css">

<script async src="https://www.googletagmanager.com/gtag/js?id=G-PHYVSFKSHL"></script>
<script>
window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', 'G-PHYVSFKSHL');
</script>
</head>
<body>

<header>
    <img src="/logo.png" alt="BGIS Logo" class="logo">
    <h1>BGIS 2026  LIVE STANDINGS</h1>
</header>

<section class="dashboard">
    <table>
        <thead>
        <tr>
            <th>#</th>
            <th>Team</th>
            <th>Matches</th>
            <th>Finishes Points</th>
            <th>Placement Points</th>
            <th>Points</th>
        </tr>
        </thead>
        <tbody id="tableBody">
        <% teams.forEach((team,index)=>{ %>
        <tr>
            <td><%= index+1 %></td>
            <td><%= team.name %></td>
            <td><%= team.matches %></td>
            <td><%= team.kills %></td>
            <td><%= team.placement %></td>
            <td><%= team.points %></td>
        </tr>
        <% }) %>
        </tbody>
    </table>

    <div class="probability">
        <h2>Live Winning Probability</h2>
        <div id="barsContainer">
        <% teams.forEach(team => { %>
            <div class="prob">
                <span><%= team.name %></span>
                <div class="bar">
                    <div class="fill" style="width:<%= team.points*2 %>%"></div>
                </div>
            </div>
        <% }) %>
        </div>
    </div>
</section>

<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();

// Render table dynamically
function renderTable(teams){
    const table = document.getElementById("tableBody");
    table.innerHTML = "";
    teams.forEach((team,index)=>{
        table.innerHTML += `
        <tr>
            <td>${index+1}</td>
            <td>${team.name}</td>
            <td>${team.kills}</td>
            <td>${team.placement}</td>
            <td>${team.points}</td>
        </tr>`;
    });
}

// Render probability bars dynamically
function renderBars(teams){
    const bars = document.getElementById("barsContainer");
    bars.innerHTML = "";
    teams.forEach(team=>{
        bars.innerHTML += `
        <div class="prob">
            <span>${team.name}</span>
            <div class="bar">
                <div class="fill" style="width:${team.points*2}%"></div>
            </div>
        </div>`;
    });
}

// Initial render
renderTable(<%= JSON.stringify(teams) %>);
renderBars(<%= JSON.stringify(teams) %>);

// Live updates from server
socket.on("updateTable", teams=>{
    teams.sort((a,b)=> b.points - a.points);
    renderTable(teams);
    renderBars(teams);
});
</script>

</body>
</html>