<!DOCTYPE html>
<html>
<head>
    
    <style>
body {
  margin: 0;
  padding: 0;
  font-family: Arial;
  color: white;
  text-align: center;

  background: radial-gradient(circle at top, #2b0057, #0a001a 70%);
}

/* REMOVE GLOW */
h1 {
  color: #c084fc;
  text-shadow: none;
}

/* GLASS TABLE */
table {
  margin: auto;
  width: 90%;
  border-collapse: collapse;

  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(12px);

  border-radius: 15px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.1);
}

th {
  background: rgba(140, 0, 255, 0.6);
}

td {
  padding: 12px;
}

tr:nth-child(even) {
  background: rgba(255,255,255,0.05);
}

tr:hover {
  background: rgba(140, 0, 255, 0.2);
}
</style>

<script>
setTimeout(() => {
  location.reload();
}, 30000); // 30 sec refresh
</script>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BGIS 2026 Live Standings</title>
    <link rel="stylesheet" href="/style.css">

<script async src="https://www.googletagmanager.com/gtag/js?id=G-PHYVSFKSHL"></script>
<script>
window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', 'G-PHYVSFKSHL');
</script>
</head>
<body>

<header>
    <img src="/logo.png" alt="BGIS Logo" class="logo">
    <h1>BGIS 2026  LIVE STANDINGS</h1>
</header>

<section class="dashboard">
    <table>
        <thead>
        <tr>
            <th>#</th>
            <th>Team</th>
            <th>Matches</th>
            <th>Finishes Points</th>
            <th>Placement Points</th>
            <th>Points</th>
        </tr>
        </thead>
        <tbody id="tableBody">
        <% teams.forEach((team,index)=>{ %>
        <tr>
            <td><%= index+1 %></td>
            <td><%= team.name %></td>
            <td><%= team.matches %></td>
            <td><%= team.kills %></td>
            <td><%= team.placement %></td>
            <td><%= team.points %></td>
        </tr>
        <% }) %>
        </tbody>
    </table>

    <div class="probability">
        <h2>Live Winning Probability</h2>
        <div id="barsContainer">
        <% teams.forEach(team => { %>
            <div class="prob">
                <span><%= team.name %></span>
                <div class="bar">
                    <div class="fill" style="width:<%= team.points*2 %>%"></div>
                </div>
            </div>
        <% }) %>
        </div>
    </div>
</section>

<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();

// Render table dynamically
function renderTable(teams){
    const table = document.getElementById("tableBody");
    table.innerHTML = "";
    teams.forEach((team,index)=>{
        table.innerHTML += `
        <tr>
            <td>${index+1}</td>
            <td>${team.name}</td>
            <td>${team.kills}</td>
            <td>${team.placement}</td>
            <td>${team.points}</td>
        </tr>`;
    });
}

// Render probability bars dynamically
function renderBars(teams){
    const bars = document.getElementById("barsContainer");
    bars.innerHTML = "";
    teams.forEach(team=>{
        bars.innerHTML += `
        <div class="prob">
            <span>${team.name}</span>
            <div class="bar">
                <div class="fill" style="width:${team.points*2}%"></div>
            </div>
        </div>`;
    });
}

// Initial render
renderTable(<%= JSON.stringify(teams) %>);
renderBars(<%= JSON.stringify(teams) %>);

// Live updates from server
socket.on("updateTable", teams=>{
    teams.sort((a,b)=> b.points - a.points);
    renderTable(teams);
    renderBars(teams);
});
</script>

</body>
</html>