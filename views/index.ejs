<!DOCTYPE html>
<html>
<head>
    
  <style>
body {
  margin: 0;
  padding: 0;
  font-family: Arial;
  color: white;
  text-align: center;

  background: url('/bg.jpg') no-repeat center center fixed;
  background-size: cover;
}

/* Overlay fix */
body::before {
  content: "";
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6);
  z-index: -1;
}

/* IMPORTANT FIX */
html, body {
  height: 100%;
}

th {
  padding: 14px;
  background: rgba(0, 0, 0, 0.6);
  color: white; /* ✅ ye add kar */
  font-weight: bold;
}
table {
  width: 90%;
  margin: auto;
}

/* MOBILE FIX */
@media (max-width: 768px) {

  h1 {
    font-size: 20px;
  }

  table {
    width: 100%;
    font-size: 12px;
  }

  th, td {
    padding: 8px;
  }

  body {
    padding: 10px;
  }
}
</style>

<script>
setTimeout(() => {
  location.reload();
}, 30000); // 30 sec refresh
</script>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BGIS 2026 Live Standings</title>
    <link rel="stylesheet" href="/style.css">

<script async src="https://www.googletagmanager.com/gtag/js?id=G-PHYVSFKSHL"></script>
<script>
window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', 'G-PHYVSFKSHL');
</script>
</head>
<body>

<header>
    <img src="/logo.png" alt="BGIS Logo" class="logo">
    <h1>BGIS 2026  LIVE STANDINGS</h1>
</header>

<section class="dashboard">
    <div style="overflow-x:auto;">
  <!-- table yaha daal -->
</div>


<table>
        <thead>
        <tr>
            <th>#</th>
            <th>Team</th>
            <th>Matches</th>
            <th>Finishes Points</th>
            <th>Placement Points</th>
            <th>Points</th>
        </tr>
        </thead>
        <tbody id="tableBody">
        <% teams.forEach((team,index)=>{ %>
        <tr>
            <td><%= index+1 %></td>
            <td><%= team.name %></td>
            <td><%= team.matches %></td>
            <td><%= team.kills %></td>
            <td><%= team.placement %></td>
            <td><%= team.points %></td>
        </tr>
        <% }) %>
        </tbody>
    </table> 

    <div class="probability">
        <h2>Live Winning Probability</h2>
        <div id="barsContainer">
        <% teams.forEach(team => { %>
            <div class="prob">
                <span><%= team.name %></span>
                <div class="bar">
                    <div class="fill" style="width:<%= team.points*2 %>%"></div>
                </div>
            </div>
        <% }) %>
        </div>
    </div>
</section>

<script src="/socket.io/socket.io.js"></script>
<script>
const socket = io();

// Render table dynamically
function renderTable(teams){
    const table = document.getElementById("tableBody");
    table.innerHTML = "";
    teams.forEach((team,index)=>{
        table.innerHTML += `
        <tr>
            <td>${index+1}</td>
            <td>${team.name}</td>
            <td>${team.kills}</td>
            <td>${team.placement}</td>
            <td>${team.points}</td>
        </tr>`;
    });
}

// Render probability bars dynamically
function renderBars(teams){
    const bars = document.getElementById("barsContainer");
    bars.innerHTML = "";
    teams.forEach(team=>{
        bars.innerHTML += `
        <div class="prob">
            <span>${team.name}</span>
            <div class="bar">
                <div class="fill" style="width:${team.points*2}%"></div>
            </div>
        </div>`;
    });
}

// Initial render
renderTable(<%= JSON.stringify(teams) %>);
renderBars(<%= JSON.stringify(teams) %>);

// Live updates from server
socket.on("updateTable", teams=>{
    teams.sort((a,b)=> b.points - a.points);
    renderTable(teams);
    renderBars(teams);
});
</script>

</body>


</html>