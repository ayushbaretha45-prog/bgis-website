<!DOCTYPE html>
<html>
<head>
    <style>
body {
  margin: 0;
  padding: 0;
  font-family: Arial;
  color: white;
  text-align: center;

  background: radial-gradient(circle at top, #2b0057, #0a001a 70%);
}

/* Heading */
h1 {
  color: #c084fc;
}

/* Form container */
form {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(12px);
  padding: 20px;
  border-radius: 15px;
  width: 300px;
  margin: 30px auto;
  box-shadow: 0 0 20px rgba(140, 0, 255, 0.3);
}

/* Inputs */
input {
  width: 90%;
  padding: 10px;
  margin: 10px 0;
  border: none;
  border-radius: 8px;
  outline: none;

  background: #1a0033;
  color: white;
}

/* Input focus glow */
input:focus {
  box-shadow: 0 0 10px #9333ea;
}

/* Button */
button {
  padding: 10px 20px;
  border: none;
  border-radius: 8px;
  background: linear-gradient(90deg, #7e22ce, #9333ea);
  color: white;
  cursor: pointer;
}

button:hover {
  background: linear-gradient(90deg, #9333ea, #c084fc);
}

/* Logout link */
a {
  color: #c084fc;
  text-decoration: none;
}
</style>
<title>Admin Panel</title>
<link rel="stylesheet" href="/style.css">
</head>
<body>

<header>
    <img src="/logo.png" alt="BGIS Logo" class="logo">
    <h1>Admin Panel</h1>
</header>

<div class="admin-container">
<p class="welcome">Welcome, <%= user %> | <a href="/logout" class="logout">Logout</a></p>

<form action="/update" method="POST" class="admin-form">
    <select name="team">
        <% teams.forEach(team=>{ %>
        <option value="<%= team.name %>"><%= team.name %></option>
        <% }) %>
    </select>

    <input type="number" name="kills" placeholder="Set Kills (optional)">
<input type="number" name="placement" placeholder="Set Placement (optional)">

<input type="number" name="addKills" placeholder="+ Add Kills">
<input type="number" name="addPlacement" placeholder="+ Add Placement">

<input type="number" name="matches" placeholder="Matches (only if change needed)">

<button type="submit">Update</button>
</form>
</div>

</body>
</html>